# Designo backend environment — copy to .env and fill in

# Required: Claude generates the websites
ANTHROPIC_API_KEY=sk-ant-...

# Server
DESIGNO_HOST=127.0.0.1
DESIGNO_PORT=8620

# Generation model (Sonnet-class recommended for quality)
DESIGNO_LLM_MODEL=claude-sonnet-4-5
DESIGNO_LLM_MAX_TOKENS=64000

# Optional: AI hero video + artwork via fal.ai (features stay hidden / skip until set)
# FAL_KEY=
# DESIGNO_VIDEO_MODEL_DRAFT=fal-ai/minimax/hailuo-02/standard/image-to-video
# DESIGNO_VIDEO_MODEL_FINAL=fal-ai/kling-video/v3/standard/image-to-video
# DESIGNO_ARTWORK_MODEL=fal-ai/flux-pro/v1.1
# DESIGNO_PHOTO_EDIT_MODEL=fal-ai/nano-banana/edit

# Post-build design critique loop (screenshot -> vision juror -> improve).
# Each improvement round costs roughly one extra site generation in tokens.
# DESIGNO_CRITIQUE_ROUNDS=2
# DESIGNO_CRITIQUE_TARGET=8.5

# Storage (defaults to ../storage next to backend/)
# DESIGNO_STORAGE_DIR=/opt/app/designo/storage

# --- Lead generation (all optional; features hide until keys are set) ---
# Apify Google Maps scraper: find businesses without websites (paid, ~$4-7/1000)
# APIFY_TOKEN=
# Companies House API: newly incorporated UK companies (free key)
# COMPANIES_HOUSE_KEY=
# Resend: sends approved pitch emails (verify your domain in Resend first)
# RESEND_API_KEY=
# DESIGNO_OUTREACH_FROM=Designo Studio <hello@yourdomain.co.uk>
# DESIGNO_OUTREACH_REPLY_TO=you@yourdomain.co.uk
# Public base URL used in emails and prospect links
# DESIGNO_PUBLIC_URL=https://nemx.co.uk/designo

# Admin login for the Designo portal (auto-generated into settings if unset —
# check the backend log for the generated value)
# DESIGNO_ADMIN_PASSWORD=

# --- Stripe payments (features hidden until STRIPE_SECRET_KEY is set) ---
# Create an account at stripe.com, enable BACS Direct Debit in Settings → Payment methods
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# Webhook secret — create at stripe.com/webhooks, endpoint: POST /api/payments/webhook
# Events to subscribe: checkout.session.completed, invoice.payment_failed, customer.subscription.deleted
# STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: override the auto-created monthly Price ID if you create it manually in Stripe
# STRIPE_MONTHLY_PRICE_ID=price_...
# Override the default prices (in pence, e.g. 69500 = £695)
# DESIGNO_PRICE_BUILD_PENCE=69500
# DESIGNO_PRICE_MONTHLY_PENCE=5900
