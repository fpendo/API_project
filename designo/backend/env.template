# Designo backend environment — copy to .env and fill in

# Required: Claude generates the websites
ANTHROPIC_API_KEY=sk-ant-...

# Server
DESIGNO_HOST=127.0.0.1
DESIGNO_PORT=8620

# Generation model (Sonnet-class recommended for quality)
DESIGNO_LLM_MODEL=claude-sonnet-4-5
DESIGNO_LLM_MAX_TOKENS=64000

# Optional: AI hero video via fal.ai (feature stays hidden until set)
# FAL_KEY=
# DESIGNO_VIDEO_MODEL_DRAFT=fal-ai/minimax/hailuo-02/standard/image-to-video
# DESIGNO_VIDEO_MODEL_FINAL=fal-ai/kling-video/v3/standard/image-to-video

# Storage (defaults to ../storage next to backend/)
# DESIGNO_STORAGE_DIR=/opt/app/designo/storage

# --- Lead generation (all optional; features hide until keys are set) ---
# Apify Google Maps scraper: find businesses without websites (paid, ~$4-7/1000)
# APIFY_TOKEN=
# Companies House API: newly incorporated UK companies (free key)
# COMPANIES_HOUSE_KEY=
# Resend: sends approved pitch emails (verify your domain in Resend first)
# RESEND_API_KEY=
# DESIGNO_OUTREACH_FROM=Designo Studio <hello@yourdomain.co.uk>
# DESIGNO_OUTREACH_REPLY_TO=you@yourdomain.co.uk
# Public base URL used in emails and prospect links
# DESIGNO_PUBLIC_URL=https://nemx.co.uk/designo
